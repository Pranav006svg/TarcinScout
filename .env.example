# API Keys for AI-Powered College Intelligence Platform
# Copy this file to .env and fill in the values

# Gemini API Key for content refining and AI extractor
GEMINI_API_KEY=your_gemini_api_key_here

# Serper & SerpAPI Keys for Search Discovery Engine
SERPER_API_KEY=your_serper_api_key_here
SERPAPI_KEY=your_serpapi_key_here

# PostgreSQL URL if migrating database (optional)
POSTGRESQL_URL=postgres://user:password@host:port/dbname?sslmode=require
